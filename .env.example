# ═══════════════════════════════════════════════════════════════
#  BACKEND (Python Voice Agents) — Root .env
#  DO NOT add NEXT_PUBLIC_* or Google OAuth vars here.
#  Dashboard vars go in dashboard/.env.local
# ═══════════════════════════════════════════════════════════════

# LiveKit Credentials
LIVEKIT_URL=wss://your-livekit-url.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Deepgram (STT & TTS)
DEEPGRAM_API_KEY=your_deepgram_api_key

# Groq (LLM)
GROQ_API_KEY=your_groq_api_key
LLM_PROVIDER=groq
GROQ_MODEL=llama-3.3-70b-versatile

# Cerebras (LLM — Free Tier, Fast Inference)
# Get your key from: https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key
CEREBRAS_MODEL=gemma-4-31b

# Sarvam (Indian TTS)
SARVAM_API_KEY=your_sarvam_api_key
SARVAM_LANGUAGE=en-IN
SARVAM_VOICE=anushka
SARVAM_TTS_MODEL=bulbul:v2

# Vobiz / SIP Trunking Configuration
VOBIZ_SIP_TRUNK_ID=your_sip_trunk_id
VOBIZ_SIP_DOMAIN=your_domain.sip.vobiz.ai
VOBIZ_USERNAME=your_vobiz_username
VOBIZ_PASSWORD=your_vobiz_password
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX

# Vobiz REST API Credentials (for fetching logs/recordings)
VOBIZ_AUTH_ID=your_auth_id
VOBIZ_AUTH_TOKEN=your_auth_token

# Optional Configuration
TTS_PROVIDER=Sarvam

# Inbound SIP Trunk
INBOUND_TRUNK_ID=your_inbound_trunk_id
